#!/usr/bin/make -f
export PYBUILD_NAME=pinsource

%:
	dh $@ --with python3 --buildsystem=pybuild

override_dh_auto_test:
	# Tests require lgpio hardware — skip during package build

override_dh_auto_install:
	find .pybuild -name '.lgd-nfy*' | xargs rm -f 2>/dev/null || true
	dh_auto_install --buildsystem=pybuild
